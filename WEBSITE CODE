<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>SmartShop Chatbot</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f5f5f5;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }

    .chat-container {
      width: 400px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .header {
      background: #4CAF50;
      color: white;
      padding: 15px;
      text-align: center;
      font-weight: bold;
    }

    .chat-box {
      height: 400px;
      overflow-y: auto;
      padding: 10px;
    }

    .message {
      margin: 8px 0;
      padding: 10px;
      border-radius: 8px;
      max-width: 80%;
    }

    .user {
      background: #dcf8c6;
      align-self: flex-end;
    }

    .bot {
      background: #eee;
      align-self: flex-start;
    }

    .input-box {
      display: flex;
      border-top: 1px solid #ccc;
    }

    input {
      flex: 1;
      padding: 10px;
      border: none;
      outline: none;
    }

    button {
      padding: 10px 15px;
      border: none;
      background: #4CAF50;
      color: white;
      cursor: pointer;
    }
  </style>
</head>
<body>

<div class="chat-container">
  <div class="header">🛒 SmartShop Chatbot 🤖</div>
  <div class="chat-box" id="chatBox"></div>
  <div class="input-box">
    <input type="text" id="userInput" placeholder="Type a message...">
    <button onclick="sendMessage()">Send</button>
  </div>
</div>

<script>
let cart = [];

const products = {
  laptops: ["Dell Inspiron - ₹55000", "HP Pavilion - ₹60000", "Lenovo IdeaPad - ₹50000"],
  phones: ["iPhone", "Samsung", "OnePlus", "Redmi", "Vivo"],
  shoes: ["Nike Running Shoes", "Adidas Sneakers", "Puma Sports Shoes"],
  accessories: ["Wireless Mouse", "Bluetooth Headphones", "Laptop Bag"]
};

function addMessage(text, sender) {
  const chatBox = document.getElementById("chatBox");
  const msg = document.createElement("div");
  msg.className = `message ${sender}`;
  msg.innerText = text;
  chatBox.appendChild(msg);
  chatBox.scrollTop = chatBox.scrollHeight;
}

function sendMessage() {
  const input = document.getElementById("userInput");
  const userText = input.value.toLowerCase();
  if (!userText) return;

  addMessage(input.value, "user");
  input.value = "";

  let response = "Sorry, I didn't understand that.";

  if (userText.includes("hello") || userText.includes("hi")) {
    response = "Hello! How can I help you?";
  }
  else if (userText.includes("help")) {
    response = "You can ask about products, cart, orders, delivery, and more.";
  }
  else if (userText.includes("products")) {
    response = "Categories: " + Object.keys(products).join(", ");
  }
  else if (userText.includes("laptop")) {
    response = products.laptops.join("\n");
  }
  else if (userText.includes("phone")) {
    response = products.phones.join(", ");
  }
  else if (userText.includes("shoes")) {
    response = products.shoes.join(", ");
  }
  else if (userText.includes("accessories")) {
    response = products.accessories.join(", ");
  }
  else if (userText.includes("add")) {
    let item = prompt("Enter item to add:");
    if (item) {
      cart.push(item);
      response = item + " added to cart";
    }
  }
  else if (userText.includes("cart")) {
    response = cart.length ? cart.join(", ") : "Cart is empty";
  }
  else if (userText.includes("clear cart")) {
    cart = [];
    response = "Cart cleared";
  }
  else if (userText.includes("track") || userText.includes("order")) {
    response = "Your order is out for delivery 🚚";
  }
  else if (userText.includes("delivery")) {
    response = "Delivery takes 3–5 days.";
  }
  else if (userText.includes("return")) {
    response = "Return within 7 days.";
  }
  else if (userText.includes("payment")) {
    response = "We accept UPI, cards, and net banking.";
  }

  setTimeout(() => addMessage(response, "bot"), 500);
}
</script>

</body>
</html>
